{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-spec.py",
            "timeout": 5,
            "statusMessage": "Checking spec protection..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on-agent-stop.sh",
            "timeout": 10,
            "statusMessage": "Validating agent work..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/save-context.sh",
            "timeout": 10,
            "statusMessage": "Saving context snapshot..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/save-context.sh",
            "timeout": 10,
            "statusMessage": "Saving session state..."
          }
        ]
      }
    ]
  }
}
